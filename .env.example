# 실제 값은 .env 파일에 (gitignore 됨 — 절대 커밋 금지)
GCP_API_KEY=your-api-key-here

# 피드백 폼 → GitHub 이슈 생성 (웹 앱 런타임용 — Vercel 환경변수에도 설정)
# fine-grained PAT, 대상 레포에 Issues: Read and write 권한
FEEDBACK_GITHUB_TOKEN=your-github-pat-here
# 이슈를 만들 레포. 기본값 myc0603/cloud-cost (public — 제출자 이메일이 공개됨).
# 이메일 보호가 필요하면 private 레포를 만들어 지정 권장.
FEEDBACK_GITHUB_REPO=myc0603/cloud-cost
